                        "pluginVersion": "4.15.0",
                        "queryType": "table",
                        "rawSql": "SELECT\n    metric_date AS cohort_date,\n    concat('Day ', replaceAll(metric_name, 'd', '')) AS day_name,\n    toInt32(replaceAll(metric_name, 'd', '')) AS day_index,\n    metric_value AS retention\nFROM analytics.daily_metrics\nWHERE metric_name IN ('d0', 'd1', 'd2', 'd3', 'd4', 'd5', 'd6', 'd7')\nORDER BY cohort_date, day_index"
                      }
                    },
                    "refId": "A",
                    "hidden": false
